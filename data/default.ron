(
    simulation: (
        tick_rate: 60,
        rng_seed: 42,
        world_chunk_size: 256,
        toroidal_world: false,
        max_active_chunks: 512,
        target_organism_count: 100000,
        diffusion_step_size: 0.1,
        physics_integrator: "SymplecticEuler",
    ),
    render: (
        vsync: true,
        draw_debug_overlays: false,
    ),
    research: (
        snapshot_interval_ticks: 3600,
        database_path: "phylon_research.db",
    )
)
